---
import { cv } from '../content/cv';
import FadeIn from './FadeIn.astro';
---

<section id="contact" class="section-block contact" aria-labelledby="contact-heading">
  <div class="container">
    <FadeIn>
      <div class="contact__inner">
        <p class="section-label">Get in touch</p>
        <h2 id="contact-heading" class="contact__headline">{cv.contact.headline}</h2>
        <p class="contact__body">{cv.contact.body}</p>
        {cv.contact.openTo && <p class="contact__open-to">{cv.contact.openTo}</p>}
        <div class="contact__links">
          <a class="btn btn-primary" href={`mailto:${cv.person.email}`}>{cv.person.email}</a>
          <a
            class="btn btn-secondary"
            href={cv.person.linkedin}
            target="_blank"
            rel="noopener noreferrer"
          >
            LinkedIn
          </a>
        </div>
      </div>
    </FadeIn>
  </div>
</section>
