---
import { cv } from '../content/cv';

const navLinks = [
  { href: '#work', label: 'Work' },
  { href: '#cases', label: 'Cases' },
  { href: '#contact', label: 'Contact' },
];
---

<header class="nav">
  <div class="container nav__inner">
    <a class="nav__brand" href={import.meta.env.BASE_URL}>{cv.person.name}</a>

    <nav aria-label="Main navigation">
      <ul class="nav__links">
        {
          navLinks.map((link) => (
            <li>
              <a class="nav__link" href={link.href}>
                {link.label}
              </a>
            </li>
          ))
        }
        <li>
          <a
            class="nav__link"
            href={cv.person.linkedin}
            target="_blank"
            rel="noopener noreferrer"
          >
            LinkedIn
          </a>
        </li>
      </ul>
    </nav>

    <div class="nav__actions">
      <a class="btn btn-primary nav__cta" href="#contact">Let's talk</a>
      <button
        class="nav__menu-btn"
        type="button"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
        id="menu-toggle"
      >
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path
            d="M3 5h14M3 10h14M3 15h14"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"></path>
        </svg>
      </button>
    </div>
  </div>

  <nav class="nav__mobile" id="mobile-nav" aria-label="Mobile navigation">
    <ul class="nav__mobile-list">
      {
        navLinks.map((link) => (
          <li>
            <a class="nav__mobile-link" href={link.href}>
              {link.label}
            </a>
          </li>
        ))
      }
      <li>
        <a
          class="nav__mobile-link"
          href={cv.person.linkedin}
          target="_blank"
          rel="noopener noreferrer"
        >
          LinkedIn
        </a>
      </li>
    </ul>
  </nav>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const mobileNav = document.getElementById('mobile-nav');

  toggle?.addEventListener('click', () => {
    const isOpen = mobileNav?.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', String(isOpen));
    toggle.setAttribute('aria-label', isOpen ? 'Close menu' : 'Open menu');
  });

  mobileNav?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      mobileNav.classList.remove('is-open');
      toggle?.setAttribute('aria-expanded', 'false');
      toggle?.setAttribute('aria-label', 'Open menu');
    });
  });
</script>
