---
interface Props {
  title: string;
  org: string;
  problem: string;
  action: string;
  metrics?: { value: string; label: string }[];
  outcomes?: { heading: string; items: string[] };
}

const { title, org, problem, action, metrics, outcomes } = Astro.props;
const panelId = `outcomes-${title.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`;
---

<article class="case-card">
  <header class="case-card__header">
    <h3 class="case-card__title">{title}</h3>
    <p class="case-card__org">{org}</p>
  </header>
  <div class="case-card__body">
    <div>
      <h4 class="case-card__block-title">The problem</h4>
      <p class="case-card__text">{problem}</p>
    </div>
    <div>
      <h4 class="case-card__block-title">What I did</h4>
      <p class="case-card__text">{action}</p>
    </div>
  </div>
  {
    outcomes && (
      <div class="case-card__outcomes">
        <div class="case-card__outcomes-header">
          <h4 class="case-card__block-title">{outcomes.heading}</h4>
          <button
            type="button"
            class="collapsible-toggle"
            data-collapsible-toggle
            aria-expanded="false"
            aria-controls={panelId}
          >
            <span data-toggle-label>See more</span>
          </button>
        </div>
        <div id={panelId} class="collapsible-panel case-card__outcomes-panel" hidden>
          <div class="collapsible-panel-inner">
            <ul class="case-card__outcomes-list">
              {
                outcomes.items.map((item, index) => (
                  <li class="collapsible-item" style={`--item-index: ${index}`}>
                    {item}
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      </div>
    )
  }
  {
    metrics && metrics.length > 0 && (
      <div class="case-card__metrics">
        {
          metrics.map((metric) => (
            <div>
              <div class="case-card__metric-value">{metric.value}</div>
              <div class="case-card__metric-label">{metric.label}</div>
            </div>
          ))
        }
      </div>
    )
  }
</article>
